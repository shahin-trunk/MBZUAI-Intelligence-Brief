# =============================================================================
# MBZUAI Intelligence Brief - Deployment Environment
# =============================================================================
# Copy this file to deploy.env and fill in the values.
#
#   cp deploy.env.example deploy.env
#   $EDITOR deploy.env
#   docker compose up -d --build
# =============================================================================

# -- Domain -------------------------------------------------------------------
# Root domain for all services. Traefik will issue TLS certs for:
#   brief.<BASE_DOMAIN>, dispatch.<BASE_DOMAIN>, traefik.<BASE_DOMAIN>
BASE_DOMAIN=audarai.com

# Subdomain prefixes (change if needed)
FRONTEND_DOMAIN_PREFIX=brief
DISPATCHER_DOMAIN_PREFIX=dispatch
TRAEFIK_DOMAIN_PREFIX=traefik3

# -- Let's Encrypt ------------------------------------------------------------
# Email used for Let's Encrypt certificate registration and expiry notices.
LETSENCRYPT_EMAIL=admin@example.com

# -- Traefik ------------------------------------------------------------------
TRAEFIK_LOG_LEVEL=INFO
# Use staging CA for testing (avoids rate limits). Remove for production.
# TRAEFIK_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
TRAEFIK_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# -- Supabase -----------------------------------------------------------------
# Public anon key — safe for browser exposure (NEXT_PUBLIC_* is built in)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -- Site URL -----------------------------------------------------------------
# Public URL of the deployed frontend (used for OG tags, metadata, etc.)
NEXT_PUBLIC_SITE_URL=https://brief.audarai.com
SITE_URL=https://brief.audarai.com

# -- Optional Services --------------------------------------------------------
# REVALIDATION_SECRET=   # Secret for ISR revalidation endpoints
# RESEND_API_KEY=        # Resend API key for email notifications
# ENABLE_AUDIO_BRIEF=false
# ENABLE_FRENCH_AUDIO=false
# GITHUB_PAT=            # GitHub PAT for audio dispatch from curation UI

# -- Dispatcher ---------------------------------------------------------------
# GitHub token with workflow dispatch permission for the target repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=shahin-trunk
GITHUB_REPO=MBZUAI-Intelligence-Brief
GITHUB_WORKFLOW_FILE=daily-brief.yml
GITHUB_REF=main
PREVENT_DUPLICATE_SAME_DAY=1
