FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg curl && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ ./backend/

# Copy celery_app.py to root so `celery -A celery_app` can find it
COPY backend/celery_app.py ./celery_app.py

ENV PYTHONPATH=/app

# Default command (overridden in docker-compose.yml for each worker type)
CMD ["celery", "-A", "celery_app", "worker", "-Q", "llm", "-c", "5", "--loglevel=info"]
